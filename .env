# ============================================
# 7zi Team Platform - Environment Configuration
# 环境配置文件 - 请勿提交到版本控制
# ============================================

# --------------------------------------------
# 基础配置 (Base Configuration)
# --------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --------------------------------------------
# 安全配置 (Security Configuration) - P0 重要!
# --------------------------------------------
# JWT 密钥 - 强随机字符串 (64 字符十六进制)
JWT_SECRET=7d8dbba1708743c54054daee77ce1966daf2af208516509e7c213b28f2e3fd15

# CSRF 密钥 - 强随机字符串 (64 字符十六进制)
CSRF_SECRET=2dc62c3f652b09885b3c2c8d322bd0a59c4d71775a91315cb3ced82533cf0dd5

# 会话配置
SESSION_MAX_AGE=86400
REFRESH_TOKEN_MAX_AGE=604800

# --------------------------------------------
# EmailJS 配置 (联系表单)
# 注册：https://www.emailjs.com/
# --------------------------------------------
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_emailjs_public_key
NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_emailjs_service_id
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_emailjs_template_id

# --------------------------------------------
# Resend API (邮件通知)
# 注册：https://resend.com/
# --------------------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --------------------------------------------
# 告警通知 (Alert Notifications)
# --------------------------------------------
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
ALERT_EMAIL_RECIPIENTS=admin@example.com

# --------------------------------------------
# 分析工具 (Analytics)
# --------------------------------------------
# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Umami Analytics
NEXT_PUBLIC_UMAMI_URL=https://umami.7zi.studio
NEXT_PUBLIC_UMAMI_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Plausible Analytics
NEXT_PUBLIC_PLAUSIBLE_ID=7zi.studio

# 百度统计 (可选)
NEXT_PUBLIC_BAIDU_ID=xxxxxxxxxxxxxxxx

# --------------------------------------------
# Redis 配置 (可选，用于缓存)
# --------------------------------------------
REDIS_URL=redis://localhost:6379

# --------------------------------------------
# Sentry 错误追踪 (可选)
# --------------------------------------------
NEXT_PUBLIC_SENTRY_RELEASE=main

# --------------------------------------------
# 多语言配置
# --------------------------------------------
BOOK_LANG=zh

# --------------------------------------------
# 子项目配置引用
# --------------------------------------------
# Auth 服务配置参考：projects/auth/.env
# Moltbook 网关配置参考：moltbook-gateway/.env
# 监控配置参考：monitoring/.env.example
ADMIN_EMAIL=admin@7zi.studio
ADMIN_PASSWORD=change_this_password
