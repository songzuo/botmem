{
  "name": "7zi-frontend",
  "version": "1.14.1",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:turbo": "next dev --turbopack",
    "dev:webpack": "USE_WEBPACK=true next dev --webpack",
    "build": "NODE_ENV=production next build",
    "build:turbo": "NODE_ENV=production TURBOPACK=1 next build --turbopack",
    "build:webpack": "NODE_ENV=production USE_WEBPACK=true next build --webpack",
    "build:analyze": "NODE_ENV=production ANALYZE=true next build",
    "build:analyze:turbo": "NODE_ENV=production ANALYZE=true TURBOPACK=1 next build --turbopack",
    "build:analyze:webpack": "NODE_ENV=production ANALYZE=true USE_WEBPACK=true next build --webpack",
    "build:check": "npm run build && node scripts/check-bundle-size.mjs",
    "build:analyze:check": "npm run build:analyze && node scripts/check-bundle-size.mjs",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css}\"",
    "test": "NODE_OPTIONS='--max-old-space-size=4096' vitest",
    "test:run": "NODE_OPTIONS='--max-old-space-size=4096' vitest run",
    "test:coverage": "NODE_OPTIONS='--max-old-space-size=4096' vitest run --coverage",
    "test:api": "cd tests/api-integration && npx vitest run",
    "test:api:watch": "cd tests/api-integration && npx vitest",
    "test:api:coverage": "cd tests/api-integration && npx vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:new": "playwright test --config=playwright.tests.config.ts",
    "test:e2e:new:ui": "playwright test --config=playwright.tests.config.ts --ui",
    "test:e2e:new:debug": "playwright test --config=playwright.tests.config.ts --debug",
    "test:e2e:new:report": "playwright show-report tests/e2e/playwright-report",
    "test:all": "npm run test:run && npm run test:e2e",
    "test:v191": "playwright test --config=playwright.v191.config.ts",
    "test:v191:ui": "playwright test --config=playwright.v191.config.ts --ui",
    "test:v191:debug": "playwright test --config=playwright.v191.config.ts --debug",
    "test:v191:report": "node scripts/generate-test-report.js && playwright show-report playwright-report/v191",
    "test:v191:workflow": "playwright test --config=playwright.v191.config.ts e2e/v191-workflow.spec.ts",
    "test:v191:task": "playwright test --config=playwright.v191.config.ts e2e/v191-task-creation.spec.ts",
    "test:v191:stress": "playwright test --config=playwright.v191.config.ts --project=stress-test",
    "benchmark": "npx tsx performance-benchmark.ts",
    "benchmark:verbose": "npx tsx performance-benchmark.ts --verbose",
    "dep:check": "madge --circular src/",
    "dep:check:graph": "madge --visualization --image dependency-graph.svg src/",
    "dep:warn": "madge --warning --circular src/ || true",
    "check:deps": "madge --warning --circular --extensions ts,tsx src/",
    "prebuild:check-deps": "madge --circular src/ || echo '⚠️ Circular dependencies found'"
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Safari versions",
    "last 2 Edge versions",
    "not dead"
  ],
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "@hono/node-server": "^1.19.14",
    "@jest/globals": "^30.3.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@sentry/nextjs": "^10.44.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/bull": "^3.15.9",
    "@types/jszip": "^3.4.0",
    "@types/lodash": "^4.17.24",
    "@xyflow/react": "^12.10.2",
    "better-sqlite3": "^12.8.0",
    "bull": "^1.1.3",
    "commander": "^14.0.3",
    "dompurify": "^3.4.0",
    "exceljs": "^3.4.0",
    "fuse.js": "^7.1.0",
    "glob": "^13.0.6",
    "handlebars": "^4.7.9",
    "hono": "^4.12.14",
    "html2canvas": "^1.4.1",
    "ioredis": "^5.10.1",
    "isomorphic-dompurify": "^3.6.0",
    "jose": "^6.2.1",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "lodash": "^4.18.1",
    "lodash-es": "^4.18.1",
    "lru-cache": "^11.2.7",
    "lucide-react": "^1.7.0",
    "next": "^16.2.4",
    "next-intl": "^4.9.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-is": "^19.2.4",
    "recharts": "^3.8.0",
    "sharp": "^0.34.5",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2",
    "uuid": "^14.0.0",
    "web-vitals": "^5.1.0",
    "yjs": "^13.6.30",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/commander": "^2.12.5",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "^16.2.1",
    "eslint-plugin-storybook": "^10.3.3",
    "jsdom": "^29.0.1",
    "madge": "^8.0.0",
    "msw": "^2.12.14",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "socket.io": "^4.8.3",
    "supertest": "^7.2.2",
    "typescript": "^5",
    "vite": "^8.0.8",
    "vitest": "^4.1.2"
  },
  "pnpm": {
    "overrides": {
      "brace-expansion@>=4.0.0 <5.0.5": ">=5.0.5",
      "flatted@<=3.4.1": ">=3.4.2",
      "serialize-javascript": ">=7.0.5"
    }
  }
}
