# ============================================
# Monitoring Stack Environment Variables
# Copy to .env and fill in actual values
# ============================================

# Slack Webhook URL (for alert notifications)
# Create at: https://api.slack.com/apps
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# SendGrid API Key (for email notifications)
# Create at: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx

# Grafana Admin Credentials
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=ChangeMeInProduction123!

# Prometheus Configuration
PROMETHEUS_RETENTION_DAYS=15
PROMETHEUS_RETENTION_SIZE=5GB

# Alertmanager Configuration
ALERTMANAGER_SMTP_HOST=smtp.sendgrid.net
ALERTMANAGER_SMTP_PORT=587
ALERTMANAGER_FROM_EMAIL=alerts@7zi.studio

# Optional: Email recipients
ALERT_EMAIL_CRITICAL=admin@7zi.studio,ops@7zi.studio
ALERT_EMAIL_HIGH=admin@7zi.studio
ALERT_EMAIL_WARNING=dev@7zi.studio
ALERT_EMAIL_INFO=dev@7zi.studio

# Optional: SMS recipients (via Twilio or similar)
ALERT_SMS_CRITICAL=+86-xxx-xxxx-xxxx

# Domain Configuration
DOMAIN=7zi.studio
MONITORING_URL=https://monitoring.7zi.studio
